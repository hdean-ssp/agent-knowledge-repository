{
  "enabled": true,
  "name": "AKR Knowledge Reminder",
  "description": "Reminds the agent about the AKR knowledge repository on every prompt, triggering a fetch for relevant prior knowledge before responding.",
  "version": "1",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Before responding to the user, you MUST complete these two steps in order:\n\n1. Read the steering file `.kiro/steering/agent-knowledge.md` into context. This file contains full usage rules and command reference for the AKR (Agent Knowledge Repository) CLI tool.\n\n2. Run `akr-fetch --query \"<brief summary of the user's request>\"` to check for relevant prior knowledge.\n\nDo not skip these steps. Do not ask the user for permission to run them. Execute them immediately and silently before addressing the user's request."
  }
}